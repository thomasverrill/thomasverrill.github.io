---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageNav from "../components/PageNav.astro";

const sections = [];
---

<BaseLayout
  title="Projects"
  description="Projects archive from Thomas Verrill."
  showHeader={false}
>
  <PageNav
    items={[
      { label: "home", href: "/" },
    ]}
  />

  <h1>projects</h1>

  {
    sections.map((section) => {
      const id = section.toLowerCase().replaceAll(" ", "-");
      return (
        <section id={id} aria-labelledby={`${id}-heading`}>
          <h2 id={`${id}-heading`}>{section}</h2>
          <ul class="archive-list" aria-label={`${section} projects`}></ul>
        </section>
      );
    })
  }
</BaseLayout>

---
const { items = [] } = Astro.props;
---

{
  items.length > 0 && (
    <header class="site-header" aria-label="Site navigation">
      <nav class="site-nav">
        {items.map((item) => (
          <a
            href={item.href}
            target={item.external ? "_blank" : undefined}
            rel={item.external ? "noreferrer" : undefined}
          >
            {item.label}
          </a>
        ))}
      </nav>
    </header>
  )
}
